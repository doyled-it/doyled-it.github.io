{
  "name": "doyled-it",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "eleventy --serve --quiet",
    "build": "eleventy && npm run build:resume-pdf",
    "build:eleventy": "eleventy",
    "build:resume-pdf": "node scripts/build-resume-pdf.mjs",
    "build:resume-pdf:legacy": "echo 'Legacy pipeline retired; see Task 11 fallback clause.' && exit 1",
    "test": "node --test 'tests/**/*.test.mjs'"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "puppeteer": "^24.40.0"
  }
}
