{% set cardList = cards %}
{% set currentNum = cardNum %}
{% set total = cardList.length %}
{% set prev = cardList[(currentNum - 1 + total) % total] %}
{% set next = cardList[(currentNum + 1) % total] %}
<div class="card-footer">
  <span class="counter">{{ site.counter }}</span>
  <nav>
    <a href="{{ prev.url }}">◀ {{ prev.name }}</a>
    &nbsp;·&nbsp; card {{ currentNum }} of {{ total - 1 }} &nbsp;·&nbsp;
    <a href="{{ next.url }}">{{ next.name }} ▶</a>
  </nav>
</div>
<div class="key-hints" aria-label="Keyboard shortcuts">
  {%- set keys = [
    {key: "H", url: "/", label: "home"},
    {key: "A", url: "/about/", label: "about"},
    {key: "R", url: "/resume/", label: "résumé"},
    {key: "P", url: "/projects/", label: "projects"},
    {key: "W", url: "/words/", label: "words"},
    {key: "M", url: "/music/", label: "music"},
    {key: "C", url: "/contact/", label: "contact"}
  ] -%}
  {%- for k in keys -%}
    <a href="{{ k.url }}" class="key-hint{% if page.url == k.url %} key-hint--active{% endif %}">[{{ k.key }}] {{ k.label }}</a>
  {%- endfor -%}
</div>
