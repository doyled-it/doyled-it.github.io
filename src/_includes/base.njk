<!doctype html>
<html lang="{{ site.locale | default('en_US') | replace('_', '-') }}" dir="ltr"{% if site.goatcounterCode %} data-goatcounter="{{ site.goatcounterCode }}"{% endif %}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="only light">
    <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
    <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{% if title %}{{ title }} · {% endif %}{{ site.title }}">
    <meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:locale" content="{{ site.locale }}">
    <meta name="twitter:card" content="summary">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="preload" href="/assets/fonts/pixelify-sans.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/assets/fonts/vt323.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="/assets/css/crt.css">
    <link rel="stylesheet" href="/assets/css/buddy-select.css">
    {% if extraCSS %}
      {% for sheet in extraCSS %}
        <link rel="stylesheet" href="{{ sheet }}">
      {% endfor %}
    {% endif %}
  </head>
  <body class="desk"{% if forceBuddy %} data-force-buddy="{{ forceBuddy }}"{% endif %}>
    <a class="skip-link" href="#main">skip to content</a>
    {{ content | safe }}
    <div class="buddy-selector" id="buddy-selector"{% if forceBuddy %} hidden{% endif %}>
      <button type="button" class="buddy-toggle" id="buddy-toggle" aria-label="Choose your buddy">
        <span class="buddy-toggle-sprite" id="buddy-toggle-sprite"></span>
        <span class="buddy-toggle-name" id="buddy-toggle-name">buddy</span>
      </button>
      <div class="buddy-grid-popup" id="buddy-grid-popup" hidden>
        <div class="buddy-grid-header">CHOOSE YOUR BUDDY</div>
        <div class="buddy-grid" id="buddy-grid"></div>
      </div>
    </div>
    <script type="module" src="/assets/js/buddies.js"></script>
    <script src="/assets/js/keyboard-nav.js" defer></script>
    <script src="/assets/js/window-controls.js" defer></script>
    <script src="/assets/js/chiptune.js" defer></script>
    <script src="/assets/js/mobile-nav.js" defer></script>
    <script src="/assets/js/visitor-counter.js" defer></script>
    {% if site.goatcounterCode %}
      <script data-goatcounter="https://{{ site.goatcounterCode }}.goatcounter.com/count"
              async src="//gc.zgo.at/count.js"></script>
    {% endif %}
    {% if extraJS %}
      {% for script in extraJS %}
        <script src="{{ script }}" defer></script>
      {% endfor %}
    {% endif %}
  </body>
</html>
