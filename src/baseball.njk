---
layout: base.njk
title: baseball
cardNum: 6
cardTitle: baseball
forceBuddy: baseball
extraCSS:
  - /assets/css/baseball.css
extraJS:
  - /assets/js/baseball-tabs.js
---
{% from "baseball-panel.njk" import seasonPanel with context %}
{% set currentSeason = baseballView.currentSeasonView %}
{% set career = baseballView.allTime.stats %}
{% set careerCalc = career.calculated %}
{% set careerGames = career.games %}
{% set careerAnalytics = baseballView.allTime.careerAnalytics %}
{% set nextGame = currentSeason.league.nextUserGame if currentSeason.league %}
{% set userTeam = currentSeason.league.userTeam if currentSeason.league %}
<main class="card baseball-card" id="main">
  {% include "titlebar.njk" %}
  <div class="card-marquee" aria-hidden="true">
    <span>
      career · {{ careerGames.played }} GP · {{ careerGames.wins }}-{{ careerGames.losses }} w-l
      · AVG {{ careerCalc.AVG | fmtRate }}
      · OBP {{ careerCalc.OBP | fmtRate }}
      · SLG {{ careerCalc.SLG | fmtRate }}
      · OPS {{ careerCalc.OPS | fmtRate }}
      · {{ career.hitting.H }}H · {{ career.hitting.HR }}HR · {{ career.hitting.RBI }}RBI
      {% if careerAnalytics.streaks.activeHit > 0 %}
      · {{ careerAnalytics.streaks.activeHit }}-game hit streak
      {% endif %}
      {% if nextGame %}
      · next: {{ nextGame.dow }} {{ nextGame.date }} {{ nextGame.time }}
        {%- if nextGame.home.team == userTeam %} vs {{ nextGame.away.team }}
        {%- else %} @ {{ nextGame.home.team }}
        {%- endif %}
      {% endif %}
      ·····
    </span>
  </div>
  <div class="card-body">
    <div class="season-tabs" role="tablist" aria-label="Season">
      <button type="button" class="season-tab is-active" role="tab" aria-selected="true" data-target="allTime">All Time</button>
      {% for season in baseballView.seasonList %}
      <button type="button" class="season-tab" role="tab" aria-selected="false" data-target="{{ season.id }}">{{ season.name }}</button>
      {% endfor %}
    </div>

    {{ seasonPanel(baseballView.allTime, "allTime", true) }}
    {% for season in baseballView.seasonList %}
    {{ seasonPanel(season, season.id, false) }}
    {% endfor %}
  </div>
  {% include "footer.njk" %}
</main>
